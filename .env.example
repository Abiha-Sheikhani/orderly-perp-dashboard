# Get a free project id at https://cloud.reown.com (formerly WalletConnect Cloud).
# Without it, WalletConnect (mobile wallets / QR pairing) is disabled but
# injected wallets (MetaMask, Trust, Coinbase extension) still work fine.
VITE_WALLETCONNECT_PROJECT_ID=

# Optional — defaults to Orderly's public reference broker "woofi_pro" if unset.
# Request your own broker id from Orderly (Discord / builder onboarding form)
# for production use.
VITE_ORDERLY_BROKER_ID=woofi_pro
